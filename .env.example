# Copilot CLI server URL (start with: copilot --headless --port 3000)
COPILOT_SERVER_URL=http://localhost:3000

# GitHub authentication (one of the following)
COPILOT_GITHUB_TOKEN=ghp_...
# GH_TOKEN=...
# GITHUB_TOKEN=...

# Default model (overridden per-task in the YAML)
COPILOT_DEFAULT_MODEL=auto

# BYOK: use your own LLM API key (no GitHub auth required)
# COPILOT_BYOK_PROVIDER=anthropic
# COPILOT_BYOK_API_KEY=sk-ant-...
